# JABIS 환경변수 예시 파일
# 실제 사용 시 이 파일을 복사하여 .env 로 만들고 값을 채우세요
# .env 파일은 절대 Git에 커밋하지 마세요

# ============================================
# LLM API
# ============================================
OPENAI_API_KEY=sk-...
# 또는
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# 국가법령정보센터 OpenAPI
# ============================================
LAW_API_OC=jabis2026
LAW_API_BASE_URL=https://www.law.go.kr/DRF

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://jabis:jabis@localhost:5432/jabis_db

# ============================================
# 서버 설정
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=8501

# ============================================
# Chroma (Vector DB)
# ============================================
CHROMA_PERSIST_DIR=./data/chroma_db

# ============================================
# 기타
# ============================================
LOG_LEVEL=INFO
DEBUG=True
